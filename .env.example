# resume_optimizer/.env.example
# Copy this to .env and fill in your actual values
# NEVER commit .env to version control!

# ─── AI API Keys ───
# Get from https://console.groq.com/keys
# GROQ_API_KEY=your_groq_api_key_here

# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ─── Database ───
# MongoDB connection string from Atlas
# Format: mongodb+srv://<username>:<password>@<cluster>/?appName=Cluster0
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=Cluster0

# ─── JWT ───
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=generate_a_secure_random_string_here

# ─── Google OAuth ───
# Create at https://console.cloud.google.com/apis/credentials
# For production, create a separate OAuth client with your production domain
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─── URLs ───
# Your deployed frontend URL (no trailing slash)
FRONTEND_URL=http://localhost:5173
